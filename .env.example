# Application
SERVER_PORT=8081

# JWT used by internal tokens
PLANNI_JWT_SECRET_KEY=replace_with_a_long_random_secret
PLANNI_JWT_EXPIRATION_MS=86400000

# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase API Keys (get from Project Settings > API)
# SUPABASE_PUBLISHABLE_KEY: Cliente-side key (formerly ANON_KEY)
# SUPABASE_SECRET_KEY: Server-side key (formerly SERVICE_ROLE_KEY) 
SUPABASE_PUBLISHABLE_KEY=replace_with_supabase_publishable_key
SUPABASE_SECRET_KEY=replace_with_supabase_secret_key

# Supabase JWT Secret (from Project Settings > JWT Secret)
# Used to validate JWT tokens from Supabase Auth
SUPABASE_JWT_SECRET=replace_with_supabase_jwt_secret

# Supabase Postgres connection
PLANNI_DB_HOST=db.your-project-ref.supabase.co
PLANNI_DB_PORT=5432
PLANNI_DB_NAME=postgres
PLANNI_DB_USER=postgres
PLANNI_DB_PASSWORD=
